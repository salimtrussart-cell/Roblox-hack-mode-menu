-- =====================
-- DRAG MENU AMÉLIORÉ (système offset + container)
-- =====================
local dragging = false
local dragOffset = Vector2.new(0, 0)
local hasDragged = false
local DRAG_THRESHOLD = 5

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        hasDragged = false
        -- Calcul de l'offset entre le doigt/souris et le coin du container
        local mousePos = input.Position
        local containerPos = container.AbsolutePosition
        dragOffset = Vector2.new(mousePos.X - containerPos.X, mousePos.Y - containerPos.Y)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local mousePos = input.Position
        local newX = mousePos.X - dragOffset.X
        local newY = mousePos.Y - dragOffset.Y

        -- Vérifie si on a assez bougé pour considérer un drag
        local currentPos = container.AbsolutePosition
        local delta = Vector2.new(newX - currentPos.X, newY - currentPos.Y)

        if not hasDragged and delta.Magnitude >= DRAG_THRESHOLD then
            hasDragged = true
            titleBar.BackgroundTransparency = 0.1
        end

        if hasDragged then
            -- Clamp pour garder le menu dans l'écran
            local viewportSize = Camera.ViewportSize
            local containerWidth = container.AbsoluteSize.X
            local containerHeight = container.AbsoluteSize.Y

            newX = math.clamp(newX, 0, viewportSize.X - containerWidth)
            newY = math.clamp(newY, 0, viewportSize.Y - 30)

            container.Position = UDim2.new(0, newX, 0, newY)
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if dragging then
            dragging = false
            titleBar.BackgroundTransparency = 0.3

            -- Si on n'a PAS bougé → toggle ouverture/fermeture
            if not hasDragged then
                frame.Visible = not frame.Visible

                if frame.Visible then
                    titleBar.Text = "▼ Salim Cheat 2.67"
                    container.Size = UDim2.new(0, 160, 0, 390)
                    titleBar.Position = UDim2.new(0, 0, 1, -30)
                else
                    titleBar.Text = "▲ Salim Cheat 2.67"
                    container.Size = UDim2.new(0, 160, 0, 30)
                    titleBar.Position = UDim2.new(0, 0, 0, 0)
                end
            end

            hasDragged = false
        end
    end
end)

