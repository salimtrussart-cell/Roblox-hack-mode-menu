end)

-- =====================
-- GET CLOSEST PLAYER
-- =====================
local function getClosestPlayer()
    local closest = nil
    local shortest = FOV

    local fovCenterX, fovCenterY
    if customFovX and customFovY then
        local guiInset = GuiService:GetGuiInset()
        fovCenterX = customFovX
        fovCenterY = customFovY - guiInset.Y
    else
        local viewportSize = Camera.ViewportSize
        fovCenterX = viewportSize.X / 2
        fovCenterY = viewportSize.Y / 2
    end

    local screenCenter = Vector2.new(fovCenterX, fovCenterY)

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local head = player.Character:FindFirstChild("Head")
            local humanoid = player.Character:FindFirstChild("Humanoid")

            if head and humanoid and humanoid.Health > 0 then
                local pos, visible = Camera:WorldToViewportPoint(head.Position)

                if visible then
                    local screenPos = Vector2.new(pos.X, pos.Y)
                    local dist = (screenPos - screenCenter).Magnitude

                    if dist < shortest then
                        shortest = dist
                        closest = player
                    end
                end
            end
        end
    end

    return closest, shortest
end

-- =====================
-- SILENT AIM - HOOK
-- =====================
local silentAimTarget = nil

-- Hook les Remote Events pour rediriger les balles
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
    local args = {...}
    local method = getnamecallmethod()

    if silentAim and silentAimTarget then
        local targetHead = nil

        if silentAimTarget.Character then
            targetHead = silentAimTarget.Character:FindFirstChild("Head")
        end

        if targetHead then
            if method == "FireServer" or method == "InvokeServer" then
                for i, v in pairs(args) do
                    -- Remplacer les positions de souris/caméra par la tête de la cible
                    if typeof(v) == "Vector3" then
                        args[i] = targetHead.Position
                    elseif typeof(v) == "CFrame" then
                        args[i] = CFrame.new(v.Position, targetHead.Position)
                    elseif typeof(v) == "RaycastResult" then
                        -- Certains jeux envoient le RaycastResult
                    end
                end
                return oldNamecall(self, unpack(args))
            end
        end
    end

    return oldNamecall(self, ...)
end))

-- Hook Mouse.Hit pour les jeux qui utilisent mouse.Hit
local oldIndex
oldIndex = hookmetamethod(game, "__index", newcclosure(function(self, key)
    if silentAim and silentAimTarget then
        local targetHead = nil
        if silentAimTarget.Character then
            targetHead = silentAimTarget.Character:FindFirstChild("Head")
        end

        if targetHead then
            if self == Mouse then
                if key == "Hit" then
                    return CFrame.new(targetHead.Position)
                elseif key == "Target" then
                    return targetHead
                elseif key == "X" then
                    local pos = Camera:WorldToViewportPoint(targetHead.Position)
                    return pos.X
                elseif key == "Y" then
                    local pos = Camera:WorldToViewportPoint(targetHead.Position)
                    return pos.Y
                elseif key == "UnitRay" then
                    local origin = Camera.CFrame.Position
                    local direction = (targetHead.Position - origin).Unit
                    return Ray.new(origin, direction)
                end
            end

            -- Hook Camera:WorldToScreenPoint et ViewportPoint pour certains jeux
            if self == Camera then
                if key == "CFrame" and false then
                    -- On ne hook pas le CFrame de la caméra pour garder la vue normale
                end
            end
        end
    end

    return oldIndex(self, key)
end))

