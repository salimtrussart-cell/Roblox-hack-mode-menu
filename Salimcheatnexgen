local fovDragging = false

local function isPointInGui(point, guiObject)
    local pos = guiObject.AbsolutePosition
    local size = guiObject.AbsoluteSize
    return point.X >= pos.X and point.X <= pos.X + size.X
        and point.Y >= pos.Y and point.Y <= pos.Y + size.Y
end

UserInputService.InputBegan:Connect(function(input)
    if not fovLocked and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1) then
        local touchPos = input.Position

        -- Vérifie qu'on ne touche pas le menu (container unique)
        local onContainer = isPointInGui(touchPos, container)

        if not onContainer then
            fovDragging = true
            customFovX = touchPos.X
            customFovY = touchPos.Y
            circle.Position = UDim2.new(0, customFovX, 0, customFovY)
            centerDot.Position = UDim2.new(0, customFovX, 0, customFovY)
        end
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if fovDragging and not fovLocked and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement) then
        customFovX = input.Position.X
        customFovY = input.Position.Y
        circle.Position = UDim2.new(0, customFovX, 0, customFovY)
        centerDot.Position = UDim2.new(0, customFovX, 0, customFovY)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if fovDragging and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1) then
        fovDragging = false
    end
end)

