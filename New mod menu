-- Créer un nouveau GUI
local gui = Instance.new("ScreenGui")
gui.Parent = game.Players.LocalPlayer.PlayerGui

-- Créer un frame pour le menu
local menuFrame = Instance.new("Frame")
menuFrame.Parent = gui
menuFrame.Size = UDim2.new(0.2, 0, 0.4, 0)
menuFrame.Position = UDim2.new(0.8, 0, 0.3, 0)
menuFrame.BackgroundColor3 = Color3.new(0, 0, 0)
menuFrame.BackgroundTransparency = 0.5

-- Créer des boutons pour les fonctionnalités
local aimbotButton = Instance.new("TextButton")
aimbotButton.Parent = menuFrame
aimbotButton.Size = UDim2.new(1, 0, 0.1, 0)
aimbotButton.Position = UDim2.new(0, 0, 0, 0)
aimbotButton.Text = "Aimbot : OFF"
aimbotButton.MouseButton1Click:Connect(function()
    modMenu.aimbot.enabled = not modMenu.aimbot.enabled
    if modMenu.aimbot.enabled then
        aimbotButton.Text = "Aimbot : ON"
    else
        aimbotButton.Text = "Aimbot : OFF"
    end
end)

