-- Boutons
aimButton.MouseButton1Click:Connect(function()
    aimAssist = not aimAssist
    aimButton.Text = "Aim Assist : "..(aimAssist and "ON" or "OFF")
end)

fovButton.MouseButton1Click:Connect(function()
    showFOV = not showFOV
    fovButton.Text = "FOV Visible : "..(showFOV and "ON" or "OFF")
    circle.Visible = showFOV
    circle.BorderColor3 = showFOV and Color3.fromRGB(255,0,0) or Color3.fromRGB(255,255,255)
end)

espButton.MouseButton1Click:Connect(function()
    espEnabled = not espEnabled
    espButton.Text = "ESP : "..(espEnabled and "ON" or "OFF")
    if espEnabled then
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                createESP(player)
            end
        end
    else
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local esp = player.Character:FindFirstChild("ESP")
                if esp then
                    esp:Destroy()
                end
            end
        end
    end
end)

fovBox.FocusLost:Connect(function()
    local num = tonumber(fovBox.Text)
    if num then
        FOV = num
        circle.Size = UDim2.new(0,FOV,0,FOV)
    end
end)

-- Fonction pour créer un ESP
local function createESP(player)
    local esp = Instance.new("BillboardGui", player.Character)
    esp.Name = "ESP"
    esp.AdjectivalFont = "Arial"
    esp.Size = UDim2.new(0, 100, 0, 50)
    esp.StudsOffset = Vector3.new(0, 3, 0)
    esp.AlwaysOnTop = true
    local espText = Instance.new("TextLabel", esp)
    espText.Size = UDim2.new(1, 0, 1, 0)
    espText.Text = player.Name
    espText.TextColor3 = Color3.new(1, 1, 1)
    espText.BackgroundTransparency = 1
end

-- Trouver cible
local function getClosestPlayer()
    local closest = nil
    local shortest = FOV
    for _,player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Head") then
            local pos,visible = Camera:WorldToViewportPoint(player.Character.Head.Position)
            if visible then
                local dist = (Vector2.new(pos.X,pos.Y) - Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)).Magnitude
                if dist < shortest then
                    shortest = dist
                    closest = player
                end
            end
        end
    end
    return closest
end

-- Aim assist
RunService.RenderStepped:Connect(function()
    if aimAssist then
        local target = getClosestPlayer()
        if target and target.Character and target.Character:FindFirstChild("Head") then
            local head = target.Character.Head
            local headPosition = head.CFrame * CFrame.new(0, head.Size.Y / 2, 0)
            local newCFrame = CFrame.new(Camera.CFrame.Position, headPosition.Position)
            Camera.CFrame = Camera.CFrame:Lerp(newCFrame, aimStrength)
        end
    end
    if espEnabled then
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local esp = player.Character:FindFirstChild("ESP")
                if not esp then
                    createESP(player)
                end
            end
        end
    end
end)
