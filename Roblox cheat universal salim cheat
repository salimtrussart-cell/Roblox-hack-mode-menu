fovInput.TextColor3 = Color3.new(1, 1, 1)
fovInput.Parent = frame

-- Configuration
local aimbot = {
    enabled = false,
    fov = 100,
    target = nil
}

local esp = {
    enabled = false
}

-- Fonctions
local function toggleAimbot()
    aimbot.enabled = not aimbot.enabled
    aimbotButton.Text = "Aimbot : " .. (aimbot.enabled and "ON" or "OFF")
end

local function toggleESP()
    esp.enabled = not esp.enabled
    espButton.Text = "ESP : " .. (esp.enabled and "ON" or "OFF")
end

local function setFOV(newFOV)
    aimbot.fov = newFOV
    fovLabel.Text = "FOV : " .. newFOV
end

-- Événements
croix.MouseButton1Click:Connect(function()
    frame.Visible = false
end)

aimbotButton.MouseButton1Click:Connect(toggleAimbot)
espButton.MouseButton1Click:Connect(toggleESP)

fovInput.FocusLost:Connect(function()
    local newFOV = tonumber(fovInput.Text)
    if newFOV then
        setFOV(newFOV)
    end
end)

